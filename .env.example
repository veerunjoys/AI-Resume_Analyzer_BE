# Server
PORT=4000
WS_PORT=4001

# CORS — comma-separated list of allowed frontend origins (add your Vercel URL here)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/recruiter_workspace

# AWS (add credentials when account is ready)
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# JWT Auth
JWT_SECRET=your_jwt_secret_here

