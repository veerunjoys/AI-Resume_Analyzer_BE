# rw-upload-orchestrator Environment Variables

# Service Port
PORT=4005

# PostgreSQL Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recruiter_workspace

# JWT Authentication Secret
JWT_SECRET=your-jwt-secret-key-here

# AWS S3 Configurations (optional/future use)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=recruiter-workspace-resumes

# Pino Logger Level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
