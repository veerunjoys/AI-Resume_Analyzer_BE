# rw-processor Environment Variables

# Service Port
PORT=4002

# PostgreSQL Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recruiter_workspace

# Upload Orchestrator Service Endpoint
UPLOAD_ORCHESTRATOR_URL=http://localhost:4000
EVENT_SYSTEM_URL=http://localhost:4000

# Redis Server URL (or 'mock' for local in-memory mock testing)
REDIS_URL=redis://127.0.0.1:6379

# JWT Authentication Secret (shared with other services)
JWT_SECRET=your-jwt-secret-key-here

# Pino Logger Level
LOG_LEVEL=info
